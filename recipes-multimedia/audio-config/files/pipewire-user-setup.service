[Unit]
Description=Enable PipeWire Audio for Edge User
After=multi-user.target home.mount edgeos-user-setup.service
Requires=home.mount
Wants=edgeos-user-setup.service
ConditionPathExists=/home/edge

[Service]
Type=oneshot
ExecStart=/usr/sbin/pipewire-user-setup.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
